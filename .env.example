# ============================================================================
# 🤖 APIs DE IA GENERATIVA (OBLIGATORIAS)
# ============================================================================
# ⚠️  REQUERIDO: El sistema necesita al menos UNA API de IA generativa configurada

# 🟢 OpenAI (Recomendado para producción)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o                    # gpt-4o, gpt-4, gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
# 💰 Costo: $0.005-0.015 por 1K tokens
# 🔗 Obtener: https://platform.openai.com/api-keys

# 🟣 Anthropic Claude (Excelente para análisis complejos)
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# 💰 Costo: $0.003-0.015 por 1K tokens  
# 🔗 Obtener: https://console.anthropic.com/

# 🔵 Google Gemini (Gratis para desarrollo)
# Configuración de Gemini AI
# Para obtener tu API key, ve a: https://makersuite.google.com/app/apikey
GEMINI_API_KEY = "TU_API_KEY_AQUI"  # Reemplaza con tu API key real
GOOGLE_MODEL=gemini-1.5-pro
# 💰 Costo: GRATIS hasta 15 req/min
# 🔗 Obtener: https://aistudio.google.com/app/apikey

# 🟡 Hugging Face (Open Source)
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct
# 💰 Costo: 1000 req/mes gratis
# 🔗 Obtener: https://huggingface.co/settings/tokens

# 🟠 Groq (Ultra rápido)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile
# 💰 Costo: Muy económico, rápido
# 🔗 Obtener: https://console.groq.com/keys

# ============================================================================
# 🔍 APIS DE BÚSQUEDA Y HERRAMIENTAS (OBLIGATORIAS)
# ============================================================================

# 🔍 Serper (Google Search - REQUERIDO)
SERPER_API_KEY=your-serper-api-key-here
# 💰 Costo: 2500 búsquedas gratis/mes
# 🔗 Obtener: https://serper.dev/

# ========================================
# CONFIGURACIÓN DE HERRAMIENTAS EXTERNAS
# ========================================

# SEMrush API (para análisis SEO/SEM)
SEMRUSH_API_KEY=your-semrush-api-key-here

# Ahrefs API (para análisis de backlinks/SEO)
AHREFS_API_TOKEN=your-ahrefs-token-here

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-property-id
GA4_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY_PATH=path/to/your/service-account-key.json

# Facebook/Meta Business API
META_ACCESS_TOKEN=your-meta-access-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# LinkedIn Marketing API
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Twitter/X API v2
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================

# PostgreSQL (para almacenar resultados y analytics)
DATABASE_URL=postgresql://user:password@localhost:5432/marketing_multiagent
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketing_multiagent
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Redis (para caché y sesiones)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# CONFIGURACIÓN DE APLICACIÓN
# ========================================

# Entorno de ejecución
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Configuración de logging
LOG_FILE_PATH=logs/marketing_multiagent.log
LOG_MAX_FILE_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Configuración de CrewAI
CREWAI_VERBOSE=True
CREWAI_MEMORY=True
CREWAI_MAX_ITERATIONS=5

# Timeouts y rate limits
API_TIMEOUT=30
MAX_RETRIES=3
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ========================================
# CONFIGURACIÓN DE OUTPUTS
# ========================================

# Directorios de salida
OUTPUTS_DIR=outputs
REPORTS_DIR=outputs/reports
LOGS_DIR=logs
TEMP_DIR=temp

# Formatos de export
DEFAULT_EXPORT_FORMAT=markdown
ENABLE_PDF_EXPORT=True
ENABLE_EXCEL_EXPORT=True

# ========================================
# CONFIGURACIÓN DE NOTIFICACIONES
# ========================================

# Slack (para notificaciones)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#marketing-ai
SLACK_USERNAME=Marketing AI Bot

# Email SMTP (para reportes por email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Marketing AI System

# ========================================
# CONFIGURACIÓN DE SEGURIDAD
# ========================================

# JWT para autenticación (si se implementa API)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encriptación de datos sensibles
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ========================================
# CONFIGURACIÓN DE DESARROLLO
# ========================================

# Para desarrollo local
DEVELOPMENT_MODE=True
MOCK_EXTERNAL_APIS=False
ENABLE_TELEMETRY=False

# Para testing
TEST_DATABASE_URL=sqlite:///test_marketing_multiagent.db
TEST_OPENAI_MODEL=gpt-3.5-turbo
TEST_MODE=False

# ========================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ========================================

# Para despliegue en producción
PRODUCTION_HOST=0.0.0.0
PRODUCTION_PORT=8000
WORKERS=4
RELOAD=False

# Monitoring y observability
ENABLE_METRICS=True
METRICS_ENDPOINT=/metrics
HEALTH_CHECK_ENDPOINT=/health

# ========================================
# CONFIGURACIÓN PERSONALIZADA
# ========================================

# Configuración específica del negocio
DEFAULT_INDUSTRY=technology
DEFAULT_TARGET_AUDIENCE=business_professionals
DEFAULT_BUDGET_RANGE=10000-50000
DEFAULT_CAMPAIGN_DURATION=90

# Configuración de modelos de IA
PRIMARY_LLM_MODEL=gpt-4o
FALLBACK_LLM_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small

# Configuración de análisis
ANALYSIS_CONFIDENCE_THRESHOLD=0.7
MIN_DATA_POINTS_FOR_ANALYSIS=50
MAX_ANALYSIS_DEPTH=comprehensive